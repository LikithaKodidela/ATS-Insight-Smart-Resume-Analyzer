# ── backend/.env.example ─────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in your real values.
# NEVER commit backend/.env to git.
#
# On your deployment platform (Railway, Render, Fly.io, etc.)
# set these as environment variables in the dashboard instead of using a file.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your-service-role-key-here          # service_role — backend only, never expose to frontend
SUPABASE_ANON_KEY=your-anon-key-here             # public anon key — also used by frontend

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match exactly what you registered in:
#   Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
AUTH_REDIRECT_URL=http://localhost:8501           # change to your production URL when deploying
                                                   # e.g. https://yourapp.streamlit.app

# ── JWT verification ─────────────────────────────────────────────────────────
# This project uses ES256 (asymmetric keys) — the secret is NOT needed.
# Tokens are verified automatically via JWKS at:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Leave this commented out unless Supabase tells you otherwise.
# SUPABASE_JWT_SECRET=

# ── Dev mode ─────────────────────────────────────────────────────────────────
# Set to true ONLY during local development to skip JWT verification.
# Must be false in production.
DEV_AUTH_BYPASS=false

# ── AI / ML ───────────────────────────────────────────────────────────────────
# Groq API key for LLM-based analysis
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Sentence transformer model (default is fine for most cases)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
