# ── frontend/.streamlit/secrets.toml.example ─────────────────────────────────
# Copy this to frontend/.streamlit/secrets.toml and fill in your real values.
# NEVER commit secrets.toml to git — it is already in .gitignore.
#
# On Streamlit Community Cloud:
#   Settings → Secrets → paste the contents (without the .example extension)

[supabase]
SUPABASE_URL      = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"

[google_oauth]
# Must match exactly what is registered in:
#   1. Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
#   2. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
#      → Authorized JavaScript origins
# For local dev:
redirect_uri = "http://localhost:8501"
# For production on Streamlit Cloud (uncomment and set your URL):
# redirect_uri = "https://your-app-name.streamlit.app"

[backend]
# HuggingFace Spaces backend URL (no trailing slash)
# For local dev:
url = "http://localhost:8000"
# For production (uncomment):
# url = "https://YOUR_HF_USERNAME-YOUR_SPACE_NAME.hf.space"
